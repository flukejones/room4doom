import {
    TexSlot,
    GfxEntry,
    PopupId,
} from "../../foundation/shared_types.slint";
import { WindowController } from "../../foundation/globals.slint";
import { Theme } from "../../foundation/theme.slint";
import { PopupScaffold } from "../../widgets/popup.slint";
import { FlatButton, DialogButtons } from "../../widgets/buttons.slint";
import { LabeledSpin } from "../../widgets/spinbox.slint";
import { TextureGrid } from "../../widgets/texture_grid.slint";

// One clickable band region overlaid on the wall image: vertical span in logical px plus the texture slot it edits.
export struct BandRect {
    y: length,
    h: length,
    slot: TexSlot,
}

// Wall editor popup: Rust populates on double-click and shows on success; close stays in Slint.
export global WallEditController {
    in-out property <bool> wall-edit-visible: false;
    in property <int> line-index: -1;
    // Active side tab: 0 front, 1 back. `has-back` hides the Back tab.
    in-out property <int> side-tab: 0;
    in property <bool> has-back: false;
    // Rendered wall for the active side and its logical size.
    in property <image> wall-img;
    in property <float> wall-w;
    in property <float> wall-h;
    // Clickable band regions over the wall, recomputed on every render.
    in property <[BandRect]> bands;
    in property <TexSlot> selected-slot;
    // Texture list (single column); `active-index` is the in-use texture's row (highlighted and scrolled into view), -1 when none.
    in property <[GfxEntry]> textures;
    in property <int> active-index: -1;
    // Selected band's sidedef offsets, editable in the spin row.
    in-out property <int> xoff;
    in-out property <int> yoff;
    in-out property <int> floor-h;
    in-out property <int> ceil-h;
    callback side-changed();
    callback select-band(TexSlot);
    callback pick-texture(string);
    callback height-changed();
    callback offset-changed();
    // Arrow-key nudge of the selected band's side offset: 1px, 10px with shift.
    callback wall-edit-key(string /* key */, bool /* shift */);
    callback apply();
    // Close edge: Rust reverts the session if Apply didn't run.
    callback wall-edit-closed();
}

// Double-clicked line editor: the wall elevation with clickable upper/mid/lower bands, a texture list, sidedef offset (arrow-nudged), and front-sector height spins. Front/Back tabs pick which sidedef is edited.
export component WallEditorPopup inherits PopupScaffold {
    visible: WallEditController.wall-edit-visible;
    title: "Edit Wall";
    id: PopupId.wall-edit;
    property <length> grid-min-w: 320px;
    // Chrome around the wall column; under-estimating crops the preview.
    property <length> preview-chrome-w: self.grid-min-w + Theme.pad + 2 * Theme.pad + 8px;
    property <length> preview-chrome-h: 28px + 2 * Theme.toolbutton-size + 20px + 24px + 4 * Theme.pad-small + 2 * Theme.pad + 12px;
    // Minimum fits the preview; enlarging the popup widens the texture grid only.
    min-width-px: max(440px, WallEditController.wall-w * 1px + self.preview-chrome-w);
    min-height-px: max(480px, WallEditController.wall-h * 1px + self.preview-chrome-h);
    geom <=> WindowController.wall-edit;
    cancelled => {
        WallEditController.wall-edit-visible = false;
    }

    HorizontalLayout {
        spacing: Theme.pad-small;

        FlatButton {
            label: "Front";
            button-min-width: 72px;
            active: WallEditController.side-tab == 0;
            clicked => {
                WallEditController.side-tab = 0;
                WallEditController.side-changed();
            }
        }

        if WallEditController.has-back: FlatButton {
            label: "Back";
            button-min-width: 72px;
            active: WallEditController.side-tab == 1;
            clicked => {
                WallEditController.side-tab = 1;
                WallEditController.side-changed();
            }
        }
    }

    HorizontalLayout {
        spacing: Theme.pad;
        vertical-stretch: 1;

        // Wall column: sized to the preview; extra popup width goes to the grid.
        Rectangle {
            width: max(64px, WallEditController.wall-w * 1px);
            background: Theme.control-bg;
            border-radius: Theme.border-radius;
            clip: true;

            wall := Image {
                source: WallEditController.wall-img;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                width: WallEditController.wall-w * 1px;
                height: WallEditController.wall-h * 1px;
                image-rendering: pixelated;

                for band in WallEditController.bands: Rectangle {
                    x: 0;
                    width: 100%;
                    y: band.y;
                    height: band.h;
                    border-width: band.slot == WallEditController.selected-slot ? 2px : 0;
                    border-color: Theme.accent;

                    band-touch := TouchArea {
                        clicked => {
                            WallEditController.select-band(band.slot);
                            fs.focus();
                        }
                    }
                }
            }
        }

        grid := TextureGrid {
            target-cell-width: 128px;
            horizontal-stretch: 1;
            min-width: root.grid-min-w;
            entries: WallEditController.textures;
            active-index: WallEditController.active-index;
            picked(name) => {
                WallEditController.pick-texture(name);
                fs.focus();
            }
        }
    }

    HorizontalLayout {
        spacing: Theme.pad-small;
        alignment: start;

        LabeledSpin {
            label: "Offset x";
            value <=> WallEditController.xoff;
            edited => {
                WallEditController.offset-changed();
            }
        }

        LabeledSpin {
            label: "y";
            value <=> WallEditController.yoff;
            edited => {
                WallEditController.offset-changed();
            }
        }
    }

    HorizontalLayout {
        spacing: Theme.pad-small;
        alignment: start;

        LabeledSpin {
            label: "Floor height";
            value <=> WallEditController.floor-h;
            edited => {
                WallEditController.height-changed();
            }
        }

        LabeledSpin {
            label: "Ceil height";
            value <=> WallEditController.ceil-h;
            edited => {
                WallEditController.height-changed();
            }
        }
    }

    DialogButtons {
        confirmed => {
            WallEditController.apply();
            WallEditController.wall-edit-visible = false;
        }
        dismissed => {
            WallEditController.wall-edit-visible = false;
        }
    }

    // Off-screen key sink: arrows nudge the active side's offset (1px, 10 with shift); everything else (incl. Escape) falls through to the scaffold. A FocusScope in a layout silently loses focus; the Rectangle takes the slot.
    Rectangle {
        width: 0;
        height: 0;
        fs := FocusScope {
            key-pressed(ev) => {
                if (ev.text == Key.UpArrow || ev.text == Key.DownArrow || ev.text == Key.LeftArrow || ev.text == Key.RightArrow) {
                    WallEditController.wall-edit-key(ev.text, ev.modifiers.shift);
                    return accept;
                }
                reject
            }
        }
    }
}
